generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Side {
  BUY
  SELL
}

enum PositionType {
  SHORT
  LONG
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

enum Role {
  USER
  ADMIN
}

model User {
  id          String           @id @default(uuid())
  username    String           @unique
  password    String
  role        Role             @default(USER)
  orders      OrderRecord[]
  maker_fills Fill[]           @relation("maker_user")
  taker_fills Fill[]           @relation("taker_user")
  positions   PositionRecord[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt()
}

model OrderRecord {
  id            String    @id @default(uuid())
  marketId      String
  side          Side
  qty           String
  initialMargin String
  leverage      String
  orderType     OrderType
  price         String
  slippage      String?
  status        String
  filledQty     String
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  maker_fills   Fill[]    @relation("maker_order")
  taker_fills   Fill[]    @relation("taker_order")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  market        Market    @relation(fields: [marketId], references: [marketId], onDelete: Cascade)
}

model Fill {
  id             String      @id @default(uuid())
  maker          String
  taker          String
  marketId       String
  qty            String
  price          String
  maker_order_id String
  taker_order_id String
  maker_order    OrderRecord @relation("maker_order", fields: [maker_order_id], references: [id], onDelete: Cascade)
  taker_order    OrderRecord @relation("taker_order", fields: [taker_order_id], references: [id], onDelete: Cascade)
  makerUser      User        @relation("maker_user", fields: [maker], references: [id], onDelete: Cascade)
  takerUser      User        @relation("taker_user", fields: [taker], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  market         Market      @relation(fields: [marketId], references: [marketId], onDelete: Cascade)
}

model PositionRecord {
  id               String       @id @default(uuid())
  marketId         String
  type             PositionType
  positionSize     String
  margin           String
  liquidationPrice String
  realisedPnL      String
  averagePrice     String
  userId           String
  equity           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  market           Market       @relation(fields: [marketId], references: [marketId], onDelete: Cascade)
}

model Market {
  id              String           @id @default(uuid())
  marketId        String           @unique
  imageUrl        String
  orders          OrderRecord[]
  fills           Fill[]
  positionRecords PositionRecord[]
}
