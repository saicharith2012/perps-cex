generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Type {
  SHORT
  LONG
}

enum OrderType {
  LIMIT
  MARKET
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

model User {
  id          String           @id @default(uuid())
  username    String           @unique
  password    String
  orders      OrderRecord[]
  maker_fills Fill[]           @relation("maker_user")
  taker_fills Fill[]           @relation("taker_user")
  positions   PositionRecord[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt()
}

model OrderRecord {
  id          String    @id @default(uuid())
  market      String
  type        Type
  quantity    Int
  margin      Int
  leverage    Int
  orderType   OrderType
  price       Int
  slippage    Int?
  status      String
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  maker_fills Fill[]    @relation("maker_order")
  taker_fills Fill[]    @relation("taker_order")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Fill {
  id             String      @id @default(uuid())
  maker          String
  taker          String
  market         String
  quantity       Int
  price          Int
  long           Int
  short          Int
  userId         String
  maker_order_id String
  taker_order_id String
  maker_order    OrderRecord @relation("maker_order", fields: [maker_order_id], references: [id])
  taker_order    OrderRecord @relation("taker_order", fields: [taker_order_id], references: [id])
  makerUser      User        @relation("maker_user", fields: [maker], references: [id])
  takerUser      User        @relation("taker_user", fields: [taker], references: [id])
  createdAt      DateTime    @default(now())
}

model PositionRecord {
  id               String   @id @default(uuid())
  market           String
  type             Type
  positionSize     Int
  margin           Int
  liquidationPrice Int
  realisedPnL      Int
  averagePrice     Int
  userId           String
  equity           Int
  user             User     @relation(fields: [userId], references: [id])
  createdAt        DateTime @default(now())
}
